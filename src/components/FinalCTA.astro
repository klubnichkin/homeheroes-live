---
const phone = '(704) 555-0147';
const phoneHref = 'tel:+17045550147';
---

<section id="contact" class="relative bg-crimson-700 py-20 lg:py-28 overflow-hidden">
  <!-- Pattern overlay -->
  <div class="absolute inset-0 opacity-10" aria-hidden="true">
    <svg class="w-full h-full" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <pattern id="cta-grid" width="50" height="50" patternUnits="userSpaceOnUse">
          <path d="M 50 0 L 0 0 0 50" fill="none" stroke="white" stroke-width="1"/>
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#cta-grid)"/>
    </svg>
  </div>

  <!-- Light glow -->
  <div class="absolute -top-32 left-1/2 -translate-x-1/2 w-[600px] h-64 bg-white/10 blur-3xl rounded-full" aria-hidden="true"></div>

  <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <!-- Icon -->
    <div class="w-16 h-16 bg-white/15 border border-white/25 rounded-2xl flex items-center justify-center mx-auto mb-6">
      <svg class="w-8 h-8 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17L17.25 21A2.652 2.652 0 0021 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 11-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 004.486-6.336l-3.276 3.277a3.004 3.004 0 01-2.25-2.25l3.276-3.276a4.5 4.5 0 00-6.336 4.486c.091 1.076-.071 2.264-.904 2.95l-.102.085m-1.745 1.437L5.909 7.5H4.5L2.25 3.75l1.5-1.5L7.5 4.5v1.409l4.26 4.26m-1.745 1.437l1.745-1.437m6.615 8.206L15.75 15.75M4.867 19.125h.008v.008h-.008v-.008z"/>
      </svg>
    </div>

    <h2 class="text-3xl sm:text-4xl lg:text-5xl font-black text-white mb-5 tracking-tight leading-tight">
      Appliance Down?<br />
      We Can Be There Today.
    </h2>
    <p class="text-crimson-100 text-lg md:text-xl mb-10 max-w-2xl mx-auto leading-relaxed">
      Stop putting up with a broken appliance. Book online or call now — most appointments are confirmed within minutes.
    </p>

    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a
        href="#contact-form"
        class="inline-flex items-center justify-center gap-2 bg-white text-crimson-800 hover:bg-slate-100 font-black text-base px-8 py-4 rounded-xl transition-all duration-200 shadow-xl hover:-translate-y-0.5"
      >
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
        </svg>
        Book Online — It's Free
      </a>
      <a
        href={phoneHref}
        class="inline-flex items-center justify-center gap-2 bg-crimson-800 hover:bg-crimson-950 text-white font-bold text-base px-8 py-4 rounded-xl border border-crimson-600 transition-all duration-200 hover:-translate-y-0.5"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
          <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/>
        </svg>
        Call {phone}
      </a>
    </div>

    <!-- Hours note -->
    <p class="text-crimson-200/80 text-sm mt-8">
      Mon–Fri 7am–7pm · Sat 8am–5pm · Emergency line available 7 days
    </p>
  </div>
</section>

<!-- Contact Form section -->
<section id="contact-form" class="bg-slate-50 py-16 lg:py-20">
  <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="bg-white rounded-3xl shadow-xl border border-slate-200 p-8 lg:p-10">
      <h3 class="text-2xl font-black text-navy-950 mb-2">Request a Same-Day Quote</h3>
      <p class="text-slate-500 text-sm mb-8">Fill this out and we'll call you back within 30 minutes.</p>

      <form class="space-y-5" name="quote-request" method="POST" action="/success">
        <div class="grid sm:grid-cols-2 gap-5">
          <div>
            <label for="first-name" class="block text-sm font-semibold text-navy-900 mb-1.5">First Name</label>
            <input
              type="text" id="first-name" name="first_name" autocomplete="given-name" required
              class="w-full px-4 py-3 rounded-xl border border-slate-300 focus:border-crimson-500 focus:ring-2 focus:ring-crimson-500/20 text-sm outline-none transition-all"
              placeholder="John"
            />
          </div>
          <div>
            <label for="last-name" class="block text-sm font-semibold text-navy-900 mb-1.5">Last Name</label>
            <input
              type="text" id="last-name" name="last_name" autocomplete="family-name" required
              class="w-full px-4 py-3 rounded-xl border border-slate-300 focus:border-crimson-500 focus:ring-2 focus:ring-crimson-500/20 text-sm outline-none transition-all"
              placeholder="Smith"
            />
          </div>
        </div>

        <div class="grid sm:grid-cols-2 gap-5">
          <div>
            <label for="phone" class="block text-sm font-semibold text-navy-900 mb-1.5">Phone Number</label>
            <input
              type="tel" id="phone" name="phone" autocomplete="tel" required
              class="w-full px-4 py-3 rounded-xl border border-slate-300 focus:border-crimson-500 focus:ring-2 focus:ring-crimson-500/20 text-sm outline-none transition-all"
              placeholder="(704) 555-0100"
            />
          </div>
          <div>
            <label for="email" class="block text-sm font-semibold text-navy-900 mb-1.5">Email</label>
            <input
              type="email" id="email" name="email" autocomplete="email"
              class="w-full px-4 py-3 rounded-xl border border-slate-300 focus:border-crimson-500 focus:ring-2 focus:ring-crimson-500/20 text-sm outline-none transition-all"
              placeholder="john@example.com"
            />
          </div>
        </div>

        <div>
          <label for="appliance" class="block text-sm font-semibold text-navy-900 mb-1.5">Appliance Type</label>
          <select
            id="appliance" name="appliance" required
            class="w-full px-4 py-3 rounded-xl border border-slate-300 focus:border-crimson-500 focus:ring-2 focus:ring-crimson-500/20 text-sm outline-none transition-all bg-white appearance-none"
          >
            <option value="" disabled selected>Select appliance…</option>
            <option>Refrigerator</option>
            <option>Washer</option>
            <option>Dryer</option>
            <option>Dishwasher</option>
            <option>Oven / Range</option>
            <option>Microwave</option>
            <option>Other</option>
          </select>
        </div>

        <div>
          <label for="issue" class="block text-sm font-semibold text-navy-900 mb-1.5">Describe the Issue</label>
          <textarea
            id="issue" name="issue" rows="3" required
            class="w-full px-4 py-3 rounded-xl border border-slate-300 focus:border-crimson-500 focus:ring-2 focus:ring-crimson-500/20 text-sm outline-none transition-all resize-none"
            placeholder="Briefly describe what's happening…"
          ></textarea>
        </div>

        <button
          type="submit"
          class="w-full bg-crimson-700 hover:bg-crimson-600 text-white font-black text-base py-4 rounded-xl transition-all duration-200 shadow-lg shadow-crimson-950/25 hover:-translate-y-0.5"
        >
          Request My Free Quote →
        </button>

        <p class="text-slate-400 text-xs text-center">
          We respect your privacy. Your info is never sold or shared.
        </p>
      </form>
    </div>
  </div>
</section>
