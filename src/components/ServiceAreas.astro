---
import { phoneHref, areas } from '../data/siteData';
---

<section id="areas" class="bg-navy-section" style="padding:80px 24px 96px;position:relative;overflow:hidden">
  <div style="position:absolute;right:-60px;top:-60px;width:380px;height:380px;border-radius:50%;opacity:0.04;filter:blur(60px);background:#dc2626;pointer-events:none" aria-hidden="true"></div>
  <div style="max-width:1280px;margin:0 auto;position:relative">
    <div class="areas-grid">
      <div>
        <div style="display:flex;align-items:center;gap:9px;margin-bottom:20px">
          <img src="/images/logo.webp" alt="HomeHeroes" width="32" height="32" style="border-radius:8px;object-fit:cover" />
          <div class="sec-label" style="color:#dc3030">Service Coverage</div>
        </div>
        <h2 style="font-size:clamp(1.9rem,3vw,2.7rem);font-weight:900;color:#e8edf5;letter-spacing:-0.04em;margin:0 0 16px;line-height:1.05">
          We Come to You —<br />Across the Metro.
        </h2>
        <p style="font-size:0.95rem;color:#1e3a56;line-height:1.7;margin:0 0 30px;max-width:380px;font-weight:400">
          Certified technicians dispatched across Charlotte and every surrounding community. Within 40 miles of uptown — same day.
        </p>
        <div style="display:flex;flex-wrap:wrap;gap:10px">
          <a href="#contact-form" class="btn-red">Book Your Repair</a>
          <a href={phoneHref} style="display:inline-flex;align-items:center;justify-content:center;font-weight:700;font-size:0.88rem;color:#5a8ab0;padding:14px 26px;border-radius:10px;text-decoration:none;border:1px solid rgba(255,255,255,0.1);transition:all 0.15s"
             onmouseover="this.style.background='rgba(255,255,255,0.05)'" onmouseout="this.style.background='transparent'">
            Call to Confirm
          </a>
        </div>
      </div>
      <div>
        <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:6px">
          {areas.map(area => (
            <div style="display:flex;align-items:center;gap:6px;padding:9px 11px;border-radius:8px;border:1px solid rgba(255,255,255,0.06);background:rgba(255,255,255,0.02);transition:all 0.15s;cursor:default"
                 onmouseover="this.style.borderColor='rgba(176,22,22,0.4)';this.style.background='rgba(176,22,22,0.04)'"
                 onmouseout="this.style.borderColor='rgba(255,255,255,0.06)';this.style.background='rgba(255,255,255,0.02)'">
              <svg width="8" height="8" fill="#dc2626" viewBox="0 0 20 20" aria-hidden="true"><path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/></svg>
              <span style="font-size:0.74rem;font-weight:700;color:#7a9ab8;letter-spacing:0.01em">{area}</span>
            </div>
          ))}
        </div>
        <p style="font-size:0.67rem;color:#1e3a56;margin-top:10px;text-align:center;font-weight:500;letter-spacing:0.03em">Not on the list? Call — we may still serve your area.</p>
      </div>
    </div>
  </div>
</section>
