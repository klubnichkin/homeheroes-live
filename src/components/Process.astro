<div class="bg-white-section" style="border-top:1px solid rgba(30,50,80,0.08);border-bottom:1px solid rgba(30,50,80,0.08);padding:64px 24px 72px">
  <div style="max-width:960px;margin:0 auto">
    <div style="text-align:center;margin-bottom:52px">
      <div style="display:flex;align-items:center;justify-content:center;gap:14px;margin-bottom:12px">
        <div style="height:1px;width:48px;background:rgba(30,50,80,0.12)"></div>
        <span style="font-size:0.66rem;font-weight:800;letter-spacing:0.22em;text-transform:uppercase;color:#b01616">The Process</span>
        <div style="height:1px;width:48px;background:rgba(30,50,80,0.12)"></div>
      </div>
      <h2 style="font-size:clamp(1.6rem,3vw,2.2rem);font-weight:900;color:#060c19;letter-spacing:-0.03em;margin:0">Fixed in 3 Simple Steps</h2>
    </div>
    <div class="steps-grid">
      {[
        { n:'1', t:'Call or Book Online',   d:'Tell us the appliance and issue. We confirm your same-day appointment in minutes.'                   },
        { n:'2', t:'Tech Arrives Same Day', d:'A certified HomeHero arrives in a fully stocked service van — uniformed, on time, ready to work.'   },
        { n:'3', t:'Fixed & Guaranteed',    d:'Repaired right the first time. Backed by our 90-day parts-and-labor warranty.'                      },
      ].map(({ n, t, d }) => (
        <div style="display:flex;flex-direction:column;align-items:center;text-align:center;padding:0 16px">
          <div style="width:58px;height:58px;border-radius:14px;display:flex;align-items:center;justify-content:center;font-size:1.4rem;font-weight:900;color:#fff;margin-bottom:18px;background:linear-gradient(180deg,#d42222,#8e1010);box-shadow:0 1px 0 rgba(255,255,255,0.15) inset,0 5px 16px rgba(176,22,22,0.35)">
            {n}
          </div>
          <h3 style="font-size:0.93rem;font-weight:800;color:#060c19;margin:0 0 8px;letter-spacing:-0.01em">{t}</h3>
          <p style="font-size:0.81rem;color:#4a5e74;line-height:1.68;margin:0;font-weight:400">{d}</p>
        </div>
      ))}
    </div>
  </div>
</div>
