---
import type { BrandPage } from '../../data/brands';
import type { City } from '../../data/cities';
import SeoPageLayout from '../../layouts/SeoPageLayout.astro';
import SEOHero from './SEOHero.astro';
import FAQSection from './FAQSection.astro';
import InternalLinks from './InternalLinks.astro';
import SEOCTA from './SEOCTA.astro';

interface Props {
  brand: BrandPage;
  city: City;
  relatedServiceLinks: { title: string; href: string; description?: string }[];
  relatedSymptomLinks: { title: string; href: string; description?: string }[];
}

const { brand, city, relatedServiceLinks, relatedSymptomLinks } = Astro.props;

const canonical = `https://tryhomeheroes.com/${city.slug}/${brand.slug}`;

const schema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "@id": "https://tryhomeheroes.com/#business",
  "name": "HomeHeroes Appliance Repair",
  "description": brand.h1,
  "telephone": city.phoneHref.replace('tel:', ''),
  "url": canonical,
  "address": {
    "@type": "PostalAddress",
    "addressLocality": city.name,
    "addressRegion": city.stateAbbr,
    "addressCountry": "US"
  }
};

const priceColors: Record<string, string> = {
  'Budget': '#6b7280',
  'Mid-Range': '#2563eb',
  'Premium': '#7c3aed',
  'Luxury': '#b01616',
};
const priceColor = priceColors[brand.priceRange] || '#6b7280';

const breadcrumbs = [
  { label: city.displayName, href: `/${city.slug}/appliance-repair` },
  { label: `${brand.name} Repair`, href: '#' },
];
---

<SeoPageLayout
  title={brand.seoTitle}
  description={brand.metaDescription}
  canonical={canonical}
  schema={schema}
>
  <!-- 1. Hero -->
  <SEOHero
    h1={brand.h1}
    intro={brand.intro}
    cityName={city.displayName}
    phone={city.phone}
    phoneHref={city.phoneHref}
    imagePath="/images/team/technician-thumbsup.webp"
    imageAlt={`HomeHeroes technician servicing ${brand.name} appliances in Charlotte NC`}
    breadcrumbs={breadcrumbs}
  />

  <!-- 2. Brand Overview -->
  <section class="bg-white-section" style="padding:72px 24px">
    <div style="max-width:1200px;margin:0 auto">
      <div style="text-align:center;margin-bottom:48px">
        <div class="sec-label" style="margin-bottom:14px">Brand Overview</div>
        <h2 style="font-size:clamp(22px,3vw,34px);font-weight:800;color:#060c19;margin:0 0 16px;letter-spacing:-0.02em">
          About {brand.name} Appliances
        </h2>
        <span style={`display:inline-block;padding:6px 16px;background:${priceColor}1a;color:${priceColor};border:1px solid ${priceColor}33;border-radius:20px;font-size:13px;font-weight:700;letter-spacing:0.05em;text-transform:uppercase`}>
          {brand.priceRange}
        </span>
      </div>

      <div style="display:grid;grid-template-columns:1fr 1fr;gap:32px">
        <!-- Strengths -->
        <div class="card" style="padding:32px">
          <h3 style="font-size:18px;font-weight:700;color:#060c19;margin:0 0 20px;display:flex;align-items:center;gap:10px">
            <span style="display:inline-flex;align-items:center;justify-content:center;width:28px;height:28px;background:#dcfce7;border-radius:6px">
              <svg width="16" height="16" fill="#16a34a" viewBox="0 0 24 24" aria-hidden="true"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
            </span>
            Strengths
          </h3>
          <ul style="list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:12px">
            {brand.strengths.map(s => (
              <li style="display:flex;align-items:flex-start;gap:10px;font-size:14px;color:#374151;line-height:1.55">
                <svg width="16" height="16" fill="#16a34a" viewBox="0 0 24 24" style="flex-shrink:0;margin-top:2px" aria-hidden="true"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
                {s}
              </li>
            ))}
          </ul>
        </div>

        <!-- Known Issues -->
        <div class="card" style="padding:32px">
          <h3 style="font-size:18px;font-weight:700;color:#060c19;margin:0 0 20px;display:flex;align-items:center;gap:10px">
            <span style="display:inline-flex;align-items:center;justify-content:center;width:28px;height:28px;background:#fef2f2;border-radius:6px">
              <svg width="16" height="16" fill="#b01616" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"/></svg>
            </span>
            Known Issues We Fix
          </h3>
          <div style="display:flex;flex-direction:column;gap:16px">
            {brand.weaknesses.map(w => (
              <div style="padding:14px 16px;background:#fafafa;border-radius:10px;border-left:3px solid #b01616">
                <div style="font-size:14px;font-weight:700;color:#060c19;margin-bottom:4px">{w.issue}</div>
                <div style="font-size:13px;color:#6b7280;line-height:1.55">{w.detail}</div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 3. Appliances We Service -->
  <section class="bg-light-section" style="padding:72px 24px">
    <div style="max-width:1200px;margin:0 auto">
      <div style="text-align:center;margin-bottom:40px">
        <div class="sec-label" style="margin-bottom:14px">What We Fix</div>
        <h2 style="font-size:clamp(22px,3vw,34px);font-weight:800;color:#060c19;margin:0;letter-spacing:-0.02em">
          {brand.name} Appliances We Service in {city.name}
        </h2>
      </div>
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:14px">
        {brand.commonAppliances.map(appliance => (
          <div class="card" style="padding:18px 22px;display:flex;align-items:center;gap:12px">
            <svg width="18" height="18" fill="#b01616" viewBox="0 0 24 24" style="flex-shrink:0" aria-hidden="true"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
            <span style="font-size:14px;font-weight:600;color:#060c19">{appliance}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 4. Related Services -->
  {relatedServiceLinks.length > 0 && (
    <section class="bg-white-section" style="padding:64px 24px">
      <InternalLinks
        heading={`${brand.name} Appliance Services in ${city.name}`}
        links={relatedServiceLinks}
      />
    </section>
  )}

  <!-- 4b. Common Symptom Guides -->
  {relatedSymptomLinks.length > 0 && (
    <section class="bg-light-section" style="padding:64px 24px">
      <InternalLinks
        heading={`Common ${brand.name} Appliance Problems`}
        links={relatedSymptomLinks}
      />
    </section>
  )}

  <!-- 5. FAQ -->
  <FAQSection faqs={brand.faq} heading={`${brand.name} Repair FAQs — ${city.name}`} />

  <!-- 6. CTA -->
  <SEOCTA phone={city.phone} phoneHref={city.phoneHref} heading={`${brand.name} Appliance Down? We'll Be There Today.`} />
</SeoPageLayout>
