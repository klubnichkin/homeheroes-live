---
interface FAQ {
  q: string;
  a: string;
}

interface Props {
  faqs: FAQ[];
  heading?: string;
}

const { faqs, heading = 'Frequently Asked Questions' } = Astro.props;
---

<section class="bg-pearl-section" style="padding:72px 24px">
  <div style="max-width:860px;margin:0 auto">
    <div style="text-align:center;margin-bottom:48px">
      <div class="sec-label" style="margin-bottom:14px">FAQ</div>
      <h2 style="font-size:clamp(24px,3vw,36px);font-weight:800;color:#060c19;margin:0;letter-spacing:-0.02em">{heading}</h2>
    </div>

    <div style="display:flex;flex-direction:column;gap:16px">
      {faqs.map((faq, i) => (
        <div class="card" style="padding:28px 32px">
          <h3 style="font-size:16px;font-weight:700;color:#060c19;margin:0 0 10px;line-height:1.4">
            <span style="color:#b01616;margin-right:8px">{String(i + 1).padStart(2, '0')}.</span>
            {faq.q}
          </h3>
          <p style="font-size:15px;color:#4a5568;line-height:1.7;margin:0">{faq.a}</p>
        </div>
      ))}
    </div>
  </div>
</section>
