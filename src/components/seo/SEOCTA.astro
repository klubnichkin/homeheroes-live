---
import ContactCTA from '../ContactCTA.astro';

interface Props {
  phone: string;
  phoneHref: string;
  heading?: string;
}

const {
  phone,
  phoneHref,
  heading = "Appliance Down? We'll Be There Today.",
} = Astro.props;
---

<section style="background:linear-gradient(135deg,#b01616 0%,#8a0e0e 100%);padding:64px 24px">
  <div style="max-width:800px;margin:0 auto;text-align:center">
    <h2 style="color:#fff;font-size:clamp(24px,3.5vw,38px);font-weight:800;line-height:1.2;margin:0 0 16px;letter-spacing:-0.02em">{heading}</h2>
    <p style="color:rgba(255,255,255,0.85);font-size:17px;line-height:1.6;margin:0 0 32px">Same-day appointments available. Licensed technicians. 90-day warranty on all repairs.</p>
    <div style="display:flex;gap:14px;justify-content:center;flex-wrap:wrap">
      <a href={phoneHref} style="display:inline-flex;align-items:center;gap:8px;padding:15px 28px;background:#fff;color:#b01616;font-weight:700;font-size:16px;border-radius:10px;text-decoration:none;transition:opacity 0.2s">
        <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/></svg>
        Call {phone}
      </a>
      <a href="#contact-form" style="display:inline-flex;align-items:center;padding:15px 28px;border:2px solid rgba(255,255,255,0.5);color:#fff;font-weight:600;font-size:16px;border-radius:10px;text-decoration:none;transition:border-color 0.2s">
        Book Free Service Call
      </a>
    </div>
  </div>
</section>

<ContactCTA />
