---
interface LinkItem {
  title: string;
  href: string;
  description?: string;
}

interface Props {
  heading: string;
  links: LinkItem[];
}

const { heading, links } = Astro.props;
---

<div style="max-width:1200px;margin:0 auto;padding:0 24px">
  <h2 style="font-size:clamp(20px,2.5vw,28px);font-weight:800;color:#060c19;margin:0 0 28px;letter-spacing:-0.01em">{heading}</h2>
  <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:16px">
    {links.map(link => (
      <a href={link.href} aria-label={link.title} class="card card-lift" style="display:block;padding:20px 22px;text-decoration:none;transition:transform 0.18s,box-shadow 0.18s">
        <div style="font-size:15px;font-weight:700;color:#060c19;margin-bottom:4px;line-height:1.3">{link.title}</div>
        {link.description && (
          <div style="font-size:13px;color:#6b7280;line-height:1.5">{link.description}</div>
        )}
        <div style="margin-top:10px;font-size:13px;color:#b01616;font-weight:600">{link.title} →</div>
      </a>
    ))}
  </div>
</div>
