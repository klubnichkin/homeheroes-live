---
import { phone, phoneHref } from '../data/siteData';

// Main service groups with symptom sub-links
const serviceGroups = [
  {
    label: 'Refrigerator Repair',
    href:  '/charlotte-nc/refrigerator-repair',
    symptoms: [
      ['Refrigerator Not Cooling',  '/charlotte-nc/refrigerator-not-cooling'],
      ['Refrigerator Leaking Water','/charlotte-nc/refrigerator-leaking-water'],
      ['Refrigerator Making Noise', '/charlotte-nc/refrigerator-making-noise'],
      ['Refrigerator Ice Buildup',  '/charlotte-nc/refrigerator-ice-buildup'],
    ],
  },
  {
    label: 'Washer Repair',
    href:  '/charlotte-nc/washer-repair',
    symptoms: [
      ['Washer Not Spinning',      '/charlotte-nc/washer-not-spinning'],
      ['Washer Not Draining',      '/charlotte-nc/washer-not-draining'],
      ['Washer Leaking',           '/charlotte-nc/washer-leaking'],
      ['Washer Shaking Violently', '/charlotte-nc/washer-shaking-violently'],
    ],
  },
  {
    label: 'Dryer Repair',
    href:  '/charlotte-nc/dryer-repair',
    symptoms: [
      ['Dryer Not Heating',        '/charlotte-nc/dryer-not-heating'],
      ['Dryer Squeaking',          '/charlotte-nc/dryer-squeaking'],
      ['Dryer Taking Too Long',    '/charlotte-nc/dryer-taking-too-long-to-dry'],
    ],
  },
];

// Additional services shown as a compact row at the bottom
const moreServices = [
  ['Dishwasher Repair',      '/charlotte-nc/dishwasher-repair'],
  ['Oven Repair',            '/charlotte-nc/oven-repair'],
  ['Stove Repair',           '/charlotte-nc/stove-repair'],
  ['Microwave Repair',       '/charlotte-nc/microwave-repair'],
  ['Ice Maker Repair',       '/charlotte-nc/ice-maker-repair'],
  ['Freezer Repair',         '/charlotte-nc/freezer-repair'],
  ['Range Hood Repair',      '/charlotte-nc/range-hood-repair'],
  ['Wine Cooler Repair',     '/charlotte-nc/wine-cooler-repair'],
  ['Electric Cooktop Repair','/charlotte-nc/electric-cooktop-repair'],
];

const brandLinks = [
  ['Samsung',    '/charlotte-nc/samsung-appliance-repair'],
  ['LG',         '/charlotte-nc/lg-appliance-repair'],
  ['Whirlpool',  '/charlotte-nc/whirlpool-appliance-repair'],
  ['GE',         '/charlotte-nc/ge-appliance-repair'],
  ['Maytag',     '/charlotte-nc/maytag-appliance-repair'],
  ['Frigidaire', '/charlotte-nc/frigidaire-appliance-repair'],
  ['KitchenAid', '/charlotte-nc/kitchenaid-appliance-repair'],
  ['Bosch',      '/charlotte-nc/bosch-appliance-repair'],
  ['Sub-Zero',   '/charlotte-nc/sub-zero-appliance-repair'],
  ['Viking',     '/charlotte-nc/viking-appliance-repair'],
  ['Thermador',  '/charlotte-nc/thermador-appliance-repair'],
  ['Wolf',       '/charlotte-nc/wolf-appliance-repair'],
  ['Miele',      '/charlotte-nc/miele-appliance-repair'],
];


const chevronDown = `<svg width="11" height="11" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" class="chev" style="flex-shrink:0;transition:transform 0.2s"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>`;
---

<!-- Announcement bar -->
<div style="background:#060c19;border-bottom:1px solid rgba(255,255,255,0.04)">
  <div style="max-width:1280px;margin:0 auto;padding:0 20px;display:flex;align-items:center;justify-content:space-between;height:36px">
    <div style="display:flex;align-items:center;gap:8px;font-size:0.72rem;font-weight:600;color:#4a6a8a;letter-spacing:0.01em">
      <span style="width:6px;height:6px;border-radius:50%;background:#34d399;display:inline-block;flex-shrink:0;animation:pulse 2s infinite"></span>
      Technicians Available Now &mdash; Same-Day Across Charlotte &amp; Surrounding Areas
    </div>
    <div id="bar-hrs" style="font-size:0.67rem;font-weight:500;color:#1e3050;letter-spacing:0.04em">
      7 Days a Week · 8am–7pm · Emergency Line Available
    </div>
  </div>
</div>

<header style="position:sticky;top:0;z-index:50;background:#060c19;box-shadow:0 2px 0 #7a0e0e,0 3px 30px rgba(6,12,25,0.9)">
  <div style="max-width:1280px;margin:0 auto;padding:0 20px">
    <div style="display:flex;align-items:center;justify-content:space-between;height:62px">

      <!-- Logo -->
      <a href="/" style="display:flex;align-items:center;gap:11px;text-decoration:none;flex-shrink:0">
        <img src="/images/logo.webp" alt="HomeHeroes" width="40" height="40"
             style="border-radius:9px;object-fit:cover;box-shadow:0 0 0 1.5px rgba(176,22,22,0.55),0 3px 10px rgba(6,12,25,0.6)" />
        <div>
          <div style="font-size:1.12rem;font-weight:900;color:#fff;line-height:1;letter-spacing:-0.025em">
            Home<span style="color:#dc2626">Heroes</span>
          </div>
          <div style="font-size:0.57rem;font-weight:700;color:#1a3050;letter-spacing:0.2em;text-transform:uppercase;margin-top:2px">
            Appliance Repair · Est. 2014
          </div>
        </div>
      </a>

      <!-- Desktop nav -->
      <nav class="desktop-nav" style="align-items:center;gap:28px" aria-label="Primary">

        <!-- Areas — plain link, no wrapper, no dropdown -->
        <a href="/charlotte-nc/areas" class="nav-link">Areas</a>

        <!-- ── Services mega menu ── -->
        <div class="nav-item">
          <button class="nav-trigger" aria-haspopup="true" aria-expanded="false">
            Services
            <Fragment set:html={chevronDown} />
          </button>

          <div class="nav-dropdown mega-dropdown">
            <div class="drop-header">
              <a href="/charlotte-nc/services" class="drop-view-all">View All Services →</a>
            </div>
            <div class="mega-grid">
              {serviceGroups.map(group => (
                <div class="mega-col">
                  <a href={group.href} class="mega-service-link">{group.label}</a>
                  <div class="mega-sub-list">
                    {group.symptoms.map(([label, href]) => (
                      <a href={href} class="mega-sub-link">
                        <span class="mega-sub-arrow" aria-hidden="true">›</span>
                        {label}
                      </a>
                    ))}
                  </div>
                </div>
              ))}
            </div>
            <div class="mega-more">
              <div class="mega-more-label">More Services</div>
              <div class="mega-more-grid">
                {moreServices.map(([label, href]) => (
                  <a href={href} class="drop-link">{label}</a>
                ))}
              </div>
            </div>
          </div>
        </div>

        <!-- Brands dropdown -->
        <div class="nav-item">
          <button class="nav-trigger" aria-haspopup="true" aria-expanded="false">
            Brands
            <Fragment set:html={chevronDown} />
          </button>
          <div class="nav-dropdown">
            <div class="drop-header">
              <a href="/charlotte-nc/brands" class="drop-view-all">View All Brands →</a>
            </div>
            <div class="drop-grid">
              {brandLinks.map(([label, href]) => (
                <a href={href} class="drop-link">{label}</a>
              ))}
            </div>
          </div>
        </div>

        <!-- Blog dropdown -->
        <div class="nav-item">
          <button class="nav-trigger" aria-haspopup="true" aria-expanded="false">
            Blog
            <Fragment set:html={chevronDown} />
          </button>
          <div class="nav-dropdown blog-dropdown">
            <div class="drop-header">
              <a href="/blog/recent-repairs" class="drop-view-all">HomeHeroes Blog →</a>
            </div>
            <div style="display:flex;flex-direction:column;gap:4px;padding:4px 0">
              <a href="/blog/recent-repairs" class="blog-drop-link">
                <span class="blog-drop-icon" aria-hidden="true">🔧</span>
                <span>
                  <span class="blog-drop-title">Recent Repair Cases</span>
                  <span class="blog-drop-desc">Real jobs from Charlotte technicians</span>
                </span>
              </a>
              <a href="/blog/useful-info" class="blog-drop-link">
                <span class="blog-drop-icon" aria-hidden="true">💡</span>
                <span>
                  <span class="blog-drop-title">Useful Info</span>
                  <span class="blog-drop-desc">Maintenance guides for homeowners</span>
                </span>
              </a>
            </div>
          </div>
        </div>

        <!-- Simple nav links -->
        {[['Why Us','#why-us'],['Reviews','#reviews']].map(([l,h]) => (
          <a href={h} class="nav-link">{l}</a>
        ))}
      </nav>

      <!-- Desktop CTA -->
      <div class="desktop-cta" style="align-items:center;gap:16px">
        <a href={phoneHref} style="display:flex;align-items:center;gap:9px;text-decoration:none">
          <div style="width:33px;height:33px;border-radius:50%;background:rgba(176,22,22,0.12);border:1px solid rgba(176,22,22,0.28);display:flex;align-items:center;justify-content:center;flex-shrink:0">
            <svg width="14" height="14" fill="#dc2626" viewBox="0 0 20 20"><path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/></svg>
          </div>
          <div>
            <div style="font-size:0.93rem;font-weight:900;color:#fff;line-height:1;letter-spacing:-0.01em">{phone}</div>
            <div style="font-size:0.58rem;font-weight:700;color:#1a3050;margin-top:2px;letter-spacing:0.08em">FREE ESTIMATES</div>
          </div>
        </a>
        <a href="#contact-form" class="btn-red" style="font-size:0.82rem;padding:9px 18px">Book Now</a>
      </div>

      <!-- Mobile menu button -->
      <button id="mob-btn" aria-expanded="false" aria-controls="mob-menu" aria-label="Open menu"
              style="display:flex;padding:8px;border:none;background:none;cursor:pointer;color:#3a5a7a;border-radius:8px">
        <svg id="ic-open"  width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/></svg>
        <svg id="ic-close" width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mob-menu" style="border-top:1px solid rgba(255,255,255,0.05);background:#040a14">
    <div style="padding:8px 16px 12px">

      <!-- Areas plain link -->
      <a href="/charlotte-nc/areas" class="mob-plain-link">Areas</a>

      <!-- Services accordion -->
      <details class="mob-acc">
        <summary class="mob-acc-trigger">
          Services
          <svg width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" class="mob-chev"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
        </summary>
        <div style="padding:4px 0 8px">

          <!-- Grouped sub-sections: Refrigerator, Washer, Dryer -->
          {serviceGroups.map(group => (
            <details class="mob-sub-acc">
              <summary class="mob-sub-trigger">
                <a href={group.href} class="mob-sub-main-link" onclick="event.stopPropagation()">{group.label}</a>
                <svg width="11" height="11" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" class="mob-sub-chev"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
              </summary>
              <div class="mob-sub-links">
                {group.symptoms.map(([label, href]) => (
                  <a href={href} class="mob-symptom-link">
                    <span aria-hidden="true" style="color:#b01616;font-weight:700;margin-right:4px">›</span>
                    {label}
                  </a>
                ))}
              </div>
            </details>
          ))}

          <!-- More services flat list -->
          <div class="mob-more-label">More Services</div>
          <div class="mob-drop-grid">
            {moreServices.map(([label, href]) => (
              <a href={href} class="mob-drop-link">{label}</a>
            ))}
            <a href="/charlotte-nc/services" class="mob-view-all" style="grid-column:1/-1">View All Services →</a>
          </div>
        </div>
      </details>

      <!-- Brands accordion -->
      <details class="mob-acc">
        <summary class="mob-acc-trigger">
          Brands
          <svg width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" class="mob-chev"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
        </summary>
        <div class="mob-drop-grid">
          {brandLinks.map(([label, href]) => (
            <a href={href} class="mob-drop-link">{label}</a>
          ))}
          <a href="/charlotte-nc/brands" class="mob-view-all" style="grid-column:1/-1">View All Brands →</a>
        </div>
      </details>

      <!-- Blog accordion -->
      <details class="mob-acc">
        <summary class="mob-acc-trigger">
          Blog
          <svg width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" class="mob-chev"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
        </summary>
        <div style="padding:4px 8px 10px">
          <a href="/blog/recent-repairs" class="mob-drop-link" style="display:flex;align-items:center;gap:8px;padding:10px 12px">
            <span aria-hidden="true">🔧</span>
            <span>Recent Repair Cases</span>
          </a>
          <a href="/blog/useful-info" class="mob-drop-link" style="display:flex;align-items:center;gap:8px;padding:10px 12px">
            <span aria-hidden="true">💡</span>
            <span>Useful Info</span>
          </a>
        </div>
      </details>

      <!-- Simple links -->
      {[['Why Us','#why-us'],['Reviews','#reviews']].map(([l,h]) => (
        <a href={h} class="mob-plain-link">{l}</a>
      ))}

      <!-- CTA buttons -->
      <div style="border-top:1px solid rgba(255,255,255,0.05);margin-top:10px;padding-top:10px;display:flex;flex-direction:column;gap:8px">
        <a href={phoneHref} style="display:flex;align-items:center;gap:10px;padding:11px 14px;border-radius:10px;text-decoration:none;background:rgba(176,22,22,0.1);border:1px solid rgba(176,22,22,0.2)">
          <svg width="16" height="16" fill="#dc2626" viewBox="0 0 20 20"><path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/></svg>
          <span style="font-weight:800;color:#fff">{phone}</span>
        </a>
        <a href="#contact-form" style="display:block;text-align:center;font-weight:800;color:#fff;padding:13px;border-radius:10px;text-decoration:none;background:linear-gradient(180deg,#d42222,#8e1010)">
          Get a Free Quote
        </a>
      </div>
    </div>
  </div>
</header>

<style>
  /* ── Desktop nav plain links ── */
  .nav-link {
    font-size: 0.83rem;
    font-weight: 600;
    color: #3a5a7a;
    text-decoration: none;
    letter-spacing: 0.01em;
    transition: color 0.12s;
  }
  .nav-link:hover { color: #c8d8ea; }

  /* ── Desktop dropdown trigger ── */
  .nav-item {
    position: relative;
    padding-bottom: 12px;
    margin-bottom: -12px;
  }
  .nav-trigger {
    display: flex;
    align-items: center;
    gap: 4px;
    padding: 0;
    background: none;
    border: none;
    cursor: pointer;
    font-size: 0.83rem;
    font-weight: 600;
    color: #3a5a7a;
    letter-spacing: 0.01em;
    font-family: inherit;
    transition: color 0.12s;
  }
  .nav-item:hover .nav-trigger { color: #c8d8ea; }
  .nav-item:hover .chev { transform: rotate(180deg); }

  /* ── Base dropdown panel ── */
  .nav-dropdown {
    position: absolute;
    top: 100%;
    left: 0;
    background: #ffffff;
    border: 1px solid rgba(30,50,80,0.1);
    border-radius: 14px;
    box-shadow: 0 12px 48px rgba(6,12,25,0.16), 0 2px 8px rgba(6,12,25,0.08);
    padding: 12px;
    min-width: 380px;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transform: translateY(-6px);
    transition: opacity 0.15s ease, transform 0.15s ease, visibility 0.15s;
    z-index: 200;
  }
  /* transparent bridge between trigger and panel — must never block adjacent links */
  .nav-dropdown::before {
    content: '';
    position: absolute;
    bottom: 100%;
    left: 0;
    right: 0;
    height: 16px;
    pointer-events: none;
  }
  .nav-item:hover .nav-dropdown,
  .nav-item.is-open .nav-dropdown {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transform: translateY(0);
  }

  /* ── Dropdown header row ── */
  .drop-header {
    padding: 4px 8px 10px;
    border-bottom: 1px solid rgba(30,50,80,0.08);
    margin-bottom: 8px;
  }
  .drop-view-all {
    font-size: 0.72rem;
    font-weight: 800;
    color: #b01616;
    text-decoration: none;
    letter-spacing: 0.03em;
  }
  .drop-view-all:hover { text-decoration: underline; }

  /* ── Standard 2-col link grid (Brands) ── */
  .drop-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2px;
  }
  .drop-link {
    display: block;
    padding: 7px 10px;
    border-radius: 8px;
    font-size: 0.79rem;
    font-weight: 600;
    color: #1a2c44;
    text-decoration: none;
    white-space: nowrap;
    transition: background 0.1s, color 0.1s;
  }
  .drop-link:hover {
    background: rgba(176,22,22,0.07);
    color: #b01616;
  }

  /* ── Mega menu panel (Services) ── */
  .mega-dropdown {
    min-width: 680px;
  }

  /* 3-column grid for the main service groups */
  .mega-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 4px 12px;
    margin-bottom: 12px;
  }
  .mega-col {
    display: flex;
    flex-direction: column;
    padding: 4px 2px;
  }

  /* Bold appliance name — acts as the primary link */
  .mega-service-link {
    display: block;
    padding: 7px 10px 6px;
    font-size: 0.83rem;
    font-weight: 800;
    color: #060c19;
    text-decoration: none;
    border-radius: 8px;
    letter-spacing: -0.01em;
    transition: background 0.1s, color 0.1s;
  }
  .mega-service-link:hover {
    background: rgba(176,22,22,0.07);
    color: #b01616;
  }

  /* Symptom sub-links beneath each service group */
  .mega-sub-list {
    display: flex;
    flex-direction: column;
    gap: 1px;
    margin-top: 2px;
  }
  .mega-sub-link {
    display: flex;
    align-items: center;
    gap: 5px;
    padding: 5px 10px;
    border-radius: 7px;
    font-size: 0.74rem;
    font-weight: 500;
    color: #4a5e74;
    text-decoration: none;
    white-space: nowrap;
    transition: background 0.1s, color 0.1s;
  }
  .mega-sub-link:hover {
    background: rgba(176,22,22,0.06);
    color: #b01616;
  }
  .mega-sub-arrow {
    font-size: 0.85rem;
    color: #b01616;
    line-height: 1;
    flex-shrink: 0;
  }

  /* "More Services" section at the bottom of the mega menu */
  .mega-more {
    border-top: 1px solid rgba(30,50,80,0.08);
    padding-top: 10px;
    margin-top: 4px;
  }
  .mega-more-label {
    font-size: 0.6rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: #9aaabe;
    padding: 0 10px 6px;
  }
  .mega-more-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
  }

  /* ── Blog dropdown ── */
  .blog-dropdown {
    min-width: 260px;
  }
  .blog-drop-link {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 12px;
    border-radius: 9px;
    text-decoration: none;
    transition: background 0.1s;
  }
  .blog-drop-link:hover {
    background: rgba(176,22,22,0.06);
  }
  .blog-drop-icon {
    font-size: 1.2rem;
    flex-shrink: 0;
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(176,22,22,0.07);
    border-radius: 8px;
  }
  .blog-drop-title {
    display: block;
    font-size: 0.85rem;
    font-weight: 700;
    color: #060c19;
    line-height: 1.2;
  }
  .blog-drop-desc {
    display: block;
    font-size: 0.72rem;
    color: #6a7a8e;
    margin-top: 2px;
    font-weight: 400;
  }
  .blog-drop-link:hover .blog-drop-title { color: #b01616; }

  /* ── Mobile accordion ── */
  .mob-acc { list-style: none; }
  .mob-acc-trigger {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 11px 14px;
    border-radius: 8px;
    font-size: 0.875rem;
    font-weight: 600;
    color: #3a5a7a;
    cursor: pointer;
    list-style: none;
    user-select: none;
  }
  .mob-acc-trigger::-webkit-details-marker { display: none; }
  .mob-acc-trigger::marker { display: none; }
  details[open] > summary.mob-acc-trigger { color: #c8d8ea; }
  details[open] > summary.mob-acc-trigger .mob-chev { transform: rotate(180deg); }
  .mob-chev { transition: transform 0.2s; flex-shrink: 0; }

  /* ── Mobile service sub-accordion (Refrigerator / Washer / Dryer) ── */
  .mob-sub-acc {
    border-radius: 7px;
    margin: 1px 8px;
  }
  .mob-sub-trigger {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 8px 10px;
    border-radius: 7px;
    cursor: pointer;
    list-style: none;
    user-select: none;
    background: rgba(255,255,255,0.03);
  }
  .mob-sub-trigger::-webkit-details-marker { display: none; }
  .mob-sub-trigger::marker { display: none; }
  .mob-sub-main-link {
    font-size: 0.82rem;
    font-weight: 700;
    color: #c8d8ea;
    text-decoration: none;
    flex: 1;
  }
  .mob-sub-main-link:hover { color: #fff; }
  .mob-sub-chev { transition: transform 0.2s; flex-shrink: 0; color: #3a5a7a; }
  details[open] > summary.mob-sub-trigger .mob-sub-chev { transform: rotate(180deg); }
  details[open] > summary.mob-sub-trigger { background: rgba(176,22,22,0.08); }

  /* Symptom links inside mobile sub-accordion */
  .mob-sub-links {
    display: flex;
    flex-direction: column;
    gap: 1px;
    padding: 4px 10px 6px 18px;
  }
  .mob-symptom-link {
    display: flex;
    align-items: center;
    padding: 5px 8px;
    border-radius: 6px;
    font-size: 0.77rem;
    font-weight: 500;
    color: #2a4a6a;
    text-decoration: none;
    transition: color 0.1s;
  }
  .mob-symptom-link:hover { color: #c8d8ea; }

  /* "More Services" label in mobile */
  .mob-more-label {
    font-size: 0.6rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: #1a3050;
    padding: 10px 18px 4px;
  }

  /* ── Mobile dropdown grid ── */
  .mob-drop-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2px;
    padding: 4px 8px 10px;
  }
  .mob-drop-link {
    display: block;
    padding: 7px 10px;
    border-radius: 7px;
    font-size: 0.79rem;
    font-weight: 500;
    color: #2a4a6a;
    text-decoration: none;
    transition: color 0.1s;
  }
  .mob-drop-link:hover { color: #c8d8ea; }

  .mob-view-all {
    display: block;
    padding: 8px 10px 2px;
    font-size: 0.72rem;
    font-weight: 800;
    color: #b01616;
    text-decoration: none;
    letter-spacing: 0.03em;
  }

  /* ── Mobile plain link ── */
  .mob-plain-link {
    display: block;
    padding: 11px 14px;
    border-radius: 8px;
    font-size: 0.875rem;
    font-weight: 600;
    color: #3a5a7a;
    text-decoration: none;
  }

  /* ── Mobile menu & icon state — CSS-only, no JS layout reads ── */
  #mob-menu  { display: none; }
  #ic-close  { display: none; }
  #mob-menu.is-open { display: block; }
  #mob-btn[aria-expanded="true"] #ic-open  { display: none; }
  #mob-btn[aria-expanded="true"] #ic-close { display: block; }
</style>

<script>
  const btn  = document.getElementById('mob-btn')!;
  const menu = document.getElementById('mob-menu')!;

  btn.addEventListener('click', () => {
    const open = menu.classList.toggle('is-open');
    btn.setAttribute('aria-expanded', String(open));
  });

  // Close mobile menu when any <a> inside is clicked
  menu.querySelectorAll('a').forEach(a => a.addEventListener('click', () => {
    menu.classList.remove('is-open');
    btn.setAttribute('aria-expanded', 'false');
  }));

  // Click-toggle dropdowns (works on all devices, not just hover)
  const navItems = Array.from(document.querySelectorAll('.nav-item'));

  navItems.forEach(item => {
    const trigger = item.querySelector('.nav-trigger') as HTMLElement | null;
    if (!trigger) return;

    trigger.addEventListener('click', (e) => {
      e.stopPropagation();
      const isOpen = item.classList.contains('is-open');
      // Close every dropdown first
      navItems.forEach(i => {
        i.classList.remove('is-open');
        i.querySelector('.nav-trigger')?.setAttribute('aria-expanded', 'false');
      });
      // Toggle this one
      if (!isOpen) {
        item.classList.add('is-open');
        trigger.setAttribute('aria-expanded', 'true');
      }
    });

    // Keep aria-expanded in sync with CSS hover too
    item.addEventListener('mouseenter', () => {
      if (!item.classList.contains('is-open'))
        trigger.setAttribute('aria-expanded', 'true');
    });
    item.addEventListener('mouseleave', () => {
      if (!item.classList.contains('is-open'))
        trigger.setAttribute('aria-expanded', 'false');
    });
  });

  // Close open dropdown when clicking anywhere outside nav
  document.addEventListener('click', () => {
    navItems.forEach(i => {
      i.classList.remove('is-open');
      i.querySelector('.nav-trigger')?.setAttribute('aria-expanded', 'false');
    });
  });

  // Close when Escape is pressed
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      navItems.forEach(i => {
        i.classList.remove('is-open');
        i.querySelector('.nav-trigger')?.setAttribute('aria-expanded', 'false');
      });
    }
  });
</script>
