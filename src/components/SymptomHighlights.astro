---
const city = 'charlotte-nc';

const groups = [
  {
    appliance: 'Refrigerator Problems',
    icon: `<svg width="20" height="20" fill="#b01616" viewBox="0 0 24 24" aria-hidden="true"><path d="M18 2H6C5.45 2 5 2.45 5 3v18c0 .55.45 1 1 1h12c.55 0 1-.45 1-1V3c0-.55-.45-1-1-1zm-1 18H7v-9h10v9zm0-11H7V4h10v5z"/></svg>`,
    symptoms: [
      ['Refrigerator Not Cooling', `/${city}/refrigerator-not-cooling`],
      ['Refrigerator Leaking Water', `/${city}/refrigerator-leaking-water`],
      ['Refrigerator Making Noise', `/${city}/refrigerator-making-noise`],
      ['Ice & Frost Buildup', `/${city}/refrigerator-ice-buildup`],
    ],
  },
  {
    appliance: 'Washer Problems',
    icon: `<svg width="20" height="20" fill="#b01616" viewBox="0 0 24 24" aria-hidden="true"><path d="M18 2.01L6 2c-1.1 0-2 .89-2 2v16c0 1.11.89 2 2 2h12c1.11 0 2-.89 2-2V4c0-1.11-.89-1.99-2-1.99zM18 20H6v-2.78c.78-.5 2-.72 3-.72 1.55 0 3.15.78 4.5.78 1.37 0 2.7-.49 3.5-.99V20zm0-5c-.78.5-2.01.72-3 .72-1.55 0-3.15-.78-4.5-.78-1.37 0-2.7.49-3.5.99V4h11v11z"/></svg>`,
    symptoms: [
      ['Washer Not Spinning', `/${city}/washer-not-spinning`],
      ['Washer Not Draining', `/${city}/washer-not-draining`],
      ['Washer Leaking Water', `/${city}/washer-leaking`],
      ['Washer Shaking Violently', `/${city}/washer-shaking-violently`],
    ],
  },
  {
    appliance: 'Dryer Problems',
    icon: `<svg width="20" height="20" fill="#b01616" viewBox="0 0 24 24" aria-hidden="true"><path d="M18.32 4.26C17.43 3.47 16.27 3 15 3H5C3.34 3 2 4.34 2 6v12c0 1.66 1.34 3 3 3h10c1.27 0 2.43-.47 3.32-1.26l3.95-3.95c.52-.52.73-1.24.73-1.79s-.21-1.27-.73-1.79l-3.95-3.95zM16 12c0 3.31-2.69 6-6 6S4 15.31 4 12s2.69-6 6-6 6 2.69 6 6zm-6 4c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4z"/></svg>`,
    symptoms: [
      ['Dryer Not Heating', `/${city}/dryer-not-heating`],
      ['Dryer Squeaking', `/${city}/dryer-squeaking`],
      ['Dryer Taking Too Long', `/${city}/dryer-taking-too-long-to-dry`],
    ],
  },
];
---

<section id="common-problems" style="padding:80px 24px 96px;background:#f8f9fc">
  <div style="max-width:1280px;margin:0 auto">
    <div style="display:flex;flex-wrap:wrap;align-items:flex-end;justify-content:space-between;gap:24px;margin-bottom:52px">
      <div>
        <div class="sec-label" style="margin-bottom:14px">Symptom Guide</div>
        <h2 style="font-size:clamp(1.9rem,3.5vw,2.9rem);font-weight:900;letter-spacing:-0.04em;color:#060c19;margin:0;line-height:1.05">
          What's Wrong With<br />Your Appliance?
        </h2>
      </div>
      <div>
        <p style="font-size:0.88rem;color:#4a5e74;line-height:1.65;margin:0 0 10px;max-width:240px;font-weight:400">Find your exact symptom and get a fast diagnosis + same-day fix.</p>
        <a href={`/${city}/common-appliance-problems`} aria-label="View all common appliance problems in Charlotte" style="display:inline-flex;align-items:center;gap:6px;font-size:0.82rem;font-weight:800;color:#b01616;text-decoration:none">
          View All Appliance Problems
          <svg width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
        </a>
      </div>
    </div>

    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:24px">
      {groups.map(group => (
        <div class="card" style="padding:28px">
          <div style="display:flex;align-items:center;gap:10px;margin-bottom:20px;padding-bottom:16px;border-bottom:1px solid rgba(30,50,80,0.08)">
            <div style="width:36px;height:36px;background:#fef2f2;border-radius:9px;display:flex;align-items:center;justify-content:center;flex-shrink:0">
              <Fragment set:html={group.icon} />
            </div>
            <h3 style="font-size:0.94rem;font-weight:800;color:#060c19;margin:0">{group.appliance}</h3>
          </div>
          <ul style="list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:6px">
            {group.symptoms.map(([label, href]) => (
              <li>
                <a href={href} style="display:flex;align-items:center;justify-content:space-between;padding:9px 12px;border-radius:7px;text-decoration:none;color:#1a2c44;font-size:0.82rem;font-weight:600;transition:background 0.1s" class="symptom-link">
                  {label}
                  <svg width="12" height="12" fill="none" viewBox="0 0 24 24" stroke="#b01616" stroke-width="2.5" style="flex-shrink:0"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .symptom-link:hover {
    background: rgba(176,22,22,0.06);
    color: #b01616;
  }
</style>
