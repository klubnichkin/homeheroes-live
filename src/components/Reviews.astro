---
import { reviews } from '../data/siteData';
---

<section id="reviews" class="bg-pearl-section" style="padding:80px 24px 96px">
  <div style="max-width:1280px;margin:0 auto">

    <div style="display:flex;flex-wrap:wrap;align-items:flex-end;justify-content:space-between;gap:24px;margin-bottom:48px">
      <div>
        <div class="sec-label" style="color:#b8922e;margin-bottom:14px">— Customer Reviews</div>
        <h2 style="font-size:clamp(1.9rem,3.5vw,2.9rem);font-weight:900;letter-spacing:-0.04em;color:#060c19;margin:0;line-height:1.05">
          What Charlotte<br />Homeowners Say
        </h2>
      </div>
      <div style="display:flex;align-items:center;gap:14px;padding:16px 20px;border-radius:14px;background:#fff;border:1px solid rgba(30,50,80,0.1);box-shadow:0 3px 14px rgba(10,20,40,0.06);flex-shrink:0">
        <img src="/images/logo.jpg" alt="HomeHeroes" width="40" height="40" style="border-radius:10px;object-fit:cover" />
        <div style="border-left:1px solid rgba(30,50,80,0.1);padding-left:14px">
          <div style="font-size:1.8rem;font-weight:900;color:#060c19;line-height:1;letter-spacing:-0.03em">4.9</div>
          <div style="color:#c09020;font-size:0.95rem;margin-top:2px">★★★★★</div>
        </div>
        <div style="border-left:1px solid rgba(30,50,80,0.1);padding-left:14px">
          <div style="font-size:0.85rem;font-weight:800;color:#060c19">200+ Reviews</div>
          <div style="font-size:0.66rem;color:#6a7a8e;margin-top:2px;font-weight:500">Google · Yelp · Facebook</div>
        </div>
      </div>
    </div>

    <!-- Featured review -->
    <div class="card card-lift" style="margin-bottom:18px;overflow:hidden">
      <div class="feat-grid">
        <div style="padding:40px 42px;display:flex;flex-direction:column;justify-content:center">
          <div style="font-size:1.05rem;color:#c09020;margin-bottom:14px;letter-spacing:3px">★★★★★</div>
          <blockquote style="font-size:1.08rem;font-weight:500;line-height:1.74;color:#1a2535;margin:0 0 22px;font-style:italic">
            "We've used HomeHeroes three times now — washer, dryer, and oven. Every single time the tech arrived on time, knew exactly what to do, and was completely honest about what actually needed to be fixed. They've earned our loyalty for life."
          </blockquote>
          <div style="display:flex;align-items:center;gap:11px">
            <div style="width:40px;height:40px;border-radius:50%;background:#0d1a30;display:flex;align-items:center;justify-content:center;color:#fff;font-weight:800;font-size:0.93rem;flex-shrink:0">J</div>
            <div>
              <div style="font-size:0.87rem;font-weight:800;color:#060c19">James & Linda W.</div>
              <div style="font-size:0.7rem;color:#6a7a8e;margin-top:2px;font-weight:500">Huntersville · Verified Customer</div>
            </div>
          </div>
        </div>
        <div style="position:relative;min-height:250px;overflow:hidden">
          <img src="/images/team/technician-thumbsup.jpg" alt="Certified HomeHeroes technician" style="width:100%;height:100%;object-fit:cover;object-position:center 10%" />
          <div style="position:absolute;inset:0;background:linear-gradient(to right,#fff 0%,transparent 30%)"></div>
        </div>
      </div>
    </div>

    <!-- 4 review cards -->
    <div class="reviews-grid">
      {reviews.map((r) => (
        <article class="card card-lift" style="padding:22px;display:flex;flex-direction:column">
          <div style="font-size:0.92rem;color:#c09020;margin-bottom:10px;letter-spacing:2px">★★★★★</div>
          <p style="font-size:0.81rem;line-height:1.7;color:#2a3a50;font-weight:400;flex:1;margin:0 0 18px">"{r.text}"</p>
          <div style="display:flex;align-items:center;gap:9px;padding-top:14px;border-top:1px solid rgba(30,50,80,0.08)">
            <div style="width:34px;height:34px;border-radius:50%;background:#0d1a30;display:flex;align-items:center;justify-content:center;color:#fff;font-size:0.8rem;font-weight:800;flex-shrink:0">{r.initial}</div>
            <div>
              <div style="font-size:0.8rem;font-weight:800;color:#060c19">{r.name}</div>
              <div style="font-size:0.66rem;color:#6a7a8e;font-weight:500">{r.location}, Charlotte</div>
            </div>
          </div>
        </article>
      ))}
    </div>

    <div style="text-align:center;margin-top:30px">
      <a href="https://g.page/r/homeheroes-charlotte" target="_blank" rel="noopener noreferrer"
         style="display:inline-flex;align-items:center;gap:7px;font-size:0.84rem;font-weight:800;color:#b01616;text-decoration:none;transition:opacity 0.15s"
         onmouseover="this.style.opacity='0.7'" onmouseout="this.style.opacity='1'">
        View All Reviews on Google
        <svg width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"/></svg>
      </a>
    </div>
  </div>
</section>
