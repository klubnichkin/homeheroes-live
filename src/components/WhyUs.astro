---
import { phone, phoneHref } from '../data/siteData';
---

<section id="why-us" class="bg-navy-section" style="padding:80px 24px 96px;position:relative;overflow:hidden">
  <div style="position:absolute;left:0;top:0;bottom:0;width:3px;background:linear-gradient(to bottom,transparent,#8a0e0e 30%,#dc2626 50%,#8a0e0e 70%,transparent)"></div>
  <div style="position:absolute;inset:0;background-image:radial-gradient(circle,rgba(255,255,255,0.022) 1px,transparent 1px);background-size:26px 26px;pointer-events:none" aria-hidden="true"></div>

  <div style="max-width:1280px;margin:0 auto;position:relative">
    <div class="why-grid">

      <!-- LEFT: Photo + stats + call card -->
      <div>
        <div style="border-radius:16px;overflow:hidden;position:relative;margin-bottom:14px;border:1px solid rgba(255,255,255,0.06);box-shadow:-4px 8px 40px rgba(0,0,0,0.35)">
          <img src="/images/services/emergency-repair-tech.webp" alt="HomeHeroes technician on a late-night emergency repair"
               width="560" height="840" loading="lazy"
               style="width:100%;height:420px;object-fit:cover;object-position:center 20%;display:block;filter:contrast(1.06) brightness(0.95) saturate(0.9)" />
          <div style="position:absolute;inset:0;background:linear-gradient(to top,rgba(6,12,25,0.55) 0%,transparent 40%)"></div>
          <div style="position:absolute;bottom:14px;left:16px">
            <div style="font-size:0.72rem;font-weight:700;color:rgba(220,230,245,0.85);letter-spacing:0.06em">EMERGENCY SERVICE · CHARLOTTE, NC</div>
          </div>
        </div>

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:12px">
          {[['10+','Years in Business'],['4,800+','Repairs Done'],['4.9★','Google Rating'],['90 Day','Warranty']].map(([v,l]) => (
            <div style="background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.07);border-radius:12px;padding:18px;text-align:center">
              <div style="font-size:1.45rem;font-weight:900;color:#e8edf5;letter-spacing:-0.03em;line-height:1">{v}</div>
              <div style="font-size:0.65rem;font-weight:700;color:#1e3252;margin-top:4px;letter-spacing:0.05em">{l}</div>
            </div>
          ))}
        </div>

        <div style="border-radius:13px;padding:20px;background:linear-gradient(135deg,#b01616,#6e0c0c);border:1px solid rgba(255,255,255,0.07);text-align:center">
          <div style="display:flex;align-items:center;justify-content:center;gap:9px;margin-bottom:11px">
            <img src="/images/logo.webp" alt="" width="30" height="30" loading="lazy" style="border-radius:8px;object-fit:cover" aria-hidden="true" />
            <div style="text-align:left">
              <div style="font-size:0.84rem;font-weight:800;color:#fff">Ready to Dispatch</div>
              <div style="font-size:0.6rem;font-weight:500;color:rgba(255,200,200,0.6);margin-top:2px">Most appointments within the hour</div>
            </div>
          </div>
          <a href={phoneHref} style="display:block;font-weight:800;font-size:0.93rem;color:#8a0e0e;padding:12px;border-radius:9px;text-decoration:none;background:#fff;transition:filter 0.15s"
             onmouseover="this.style.filter='brightness(0.95)'" onmouseout="this.style.filter='none'">
            Call {phone}
          </a>
        </div>
      </div>

      <!-- RIGHT: Feature list -->
      <div>
        <div class="sec-label" style="color:#dc3030;margin-bottom:18px">Why HomeHeroes</div>
        <h2 style="font-size:clamp(1.9rem,3vw,2.7rem);font-weight:900;color:#e8edf5;margin:0 0 10px;letter-spacing:-0.04em;line-height:1.05">
          Charlotte's Most<br />Recommended Team.
        </h2>
        <p style="font-size:0.95rem;color:#1e3a56;margin:0 0 36px;line-height:1.7;font-weight:400">Built one honest repair at a time since 2014.</p>

        <div style="display:flex;flex-direction:column;gap:2px">
          {[
            { t:'Same-Day Appointments',        d:"Call by noon and a tech is at your door today. We know a broken appliance won't wait."         },
            { t:'Upfront Flat-Rate Pricing',     d:'You see the exact price before any work begins. The quote we give is the bill you pay.'        },
            { t:'Certified, Vetted Technicians', d:'EPA-certified, background-checked, factory-trained. Uniformed, on time, professional.'        },
            { t:'OEM Parts · 90-Day Warranty',   d:'Original manufacturer parts only. Every repair backed by our 90-day guarantee.'               },
            { t:'Licensed & Fully Insured',      d:"NC licensed (#72041), fully insured. You're protected on every call."                         },
            { t:'Local Charlotte Since 2014',    d:"Not a franchise or call center. We're your neighbors — this community is our livelihood."      },
          ].map(({ t, d }) => (
            <div style="display:flex;gap:12px;padding:14px;border-radius:10px;transition:background 0.15s;cursor:default"
                 onmouseover="this.style.background='rgba(255,255,255,0.03)'" onmouseout="this.style.background='transparent'">
              <div style="margin-top:1px;width:19px;height:19px;border-radius:50%;flex-shrink:0;display:flex;align-items:center;justify-content:center;background:linear-gradient(180deg,#d42222,#8e1010)">
                <svg width="8" height="8" fill="none" viewBox="0 0 24 24" stroke="white" stroke-width="3.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
              </div>
              <div>
                <div style="font-size:0.84rem;font-weight:800;color:#e8edf5;margin-bottom:3px;letter-spacing:-0.01em">{t}</div>
                <div style="font-size:0.79rem;color:#1e3a56;line-height:1.62;font-weight:400">{d}</div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
