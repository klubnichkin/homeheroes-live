---
import { services, phoneHref } from '../data/siteData';
---

<section id="services" class="bg-white-section" style="padding:80px 24px 96px">
  <div style="max-width:1280px;margin:0 auto">
    <div style="display:flex;flex-wrap:wrap;align-items:flex-end;justify-content:space-between;gap:24px;margin-bottom:52px">
      <div>
        <div class="sec-label" style="margin-bottom:14px">What We Fix</div>
        <h2 style="font-size:clamp(1.9rem,3.5vw,2.9rem);font-weight:900;letter-spacing:-0.04em;color:#060c19;margin:0;line-height:1.05">
          Expert Repair on Every<br />Major Appliance Brand
        </h2>
      </div>
      <div>
        <p style="font-size:0.88rem;color:#4a5e74;line-height:1.65;margin:0 0 10px;max-width:230px;font-weight:400">Certified techs · OEM parts · 95%+ first-visit fix rate</p>
        <a href={phoneHref} style="display:inline-flex;align-items:center;gap:6px;font-size:0.82rem;font-weight:800;color:#b01616;text-decoration:none">
          Or call us now
          <svg width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
        </a>
      </div>
    </div>

    <div class="services-grid">
      {services.map((svc) => (
        <article class="card card-lift" style="overflow:hidden;border-radius:16px">
          <div style="height:210px;position:relative;overflow:hidden;background:#e4e8ee">
            <img src={svc.photo} alt={`${svc.title} in Charlotte, NC`} class="svc-img"
                 width="800" height="800" loading="lazy"
                 style={"width:100%;height:100%;object-fit:cover;object-position:" + svc.pos + ";filter:contrast(1.05) brightness(0.96) saturate(0.88)"} />
            <div style="position:absolute;bottom:0;left:0;right:0;height:60px;background:linear-gradient(to top,rgba(6,12,25,0.55) 0%,transparent 100%)"></div>
            <div style="position:absolute;bottom:10px;left:10px;background:rgba(176,22,22,0.88);padding:4px 10px;border-radius:6px">
              <span style="font-size:0.7rem;font-weight:800;color:#fff;letter-spacing:0.05em">{svc.from}</span>
            </div>
          </div>
          <div style="padding:20px 22px">
            <h3 style="font-size:0.96rem;font-weight:800;color:#060c19;margin:0 0 7px;letter-spacing:-0.01em">
              <a href={svc.pageHref} style="color:inherit;text-decoration:none">{svc.title}</a>
            </h3>
            <p style="font-size:0.81rem;line-height:1.68;color:#4a5e74;font-weight:400;margin:0 0 18px">{svc.desc}</p>
            <div style="border-top:1px solid rgba(30,50,80,0.08);padding-top:14px;display:flex;align-items:center;justify-content:space-between">
              <a href="#contact-form" style="display:inline-flex;align-items:center;gap:5px;font-size:0.8rem;font-weight:800;color:#b01616;text-decoration:none">
                Book Repair
                <svg width="12" height="12" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
              </a>
              <a href={svc.pageHref} aria-label={`${svc.detailLabel} in Charlotte, NC`} style="display:inline-flex;align-items:center;gap:4px;font-size:0.65rem;font-weight:700;color:#9aaabe;text-decoration:none;letter-spacing:0.06em">
                {svc.detailLabel}
                <svg width="10" height="10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
              </a>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<script>
  document.querySelectorAll('.svc-img').forEach(img => {
    const el = img as HTMLElement;
    const card = el.closest('article');
    if (card) {
      card.addEventListener('mouseenter', () => { el.style.transform = 'scale(1.05)'; });
      card.addEventListener('mouseleave', () => { el.style.transform = 'scale(1)'; });
    }
  });
</script>
